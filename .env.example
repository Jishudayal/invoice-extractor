# Copy this file to `.env` and fill in the values.
# Only the rules pipeline (Pipeline B) runs without any of these — it is fully local.

# Pipeline A — Azure OpenAI (LLM structured extraction)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Pipeline C — Azure Document Intelligence (optional, off by default)
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=

# Behaviour
LLM_TEMPERATURE=0
# Path to the tesseract binary, only if it is not on your PATH:
# TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Dataset download (scripts/download_invoices.py) — Kaggle API.
# Alternatively place credentials at ~/.kaggle/kaggle.json instead of setting these.
KAGGLE_USERNAME=
KAGGLE_KEY=
